{
  "id": "gre-quant",
  "title": "GRE Quantitative Reasoning",
  "exam": "GRE",
  "section": "Quantitative Reasoning",
  "description": "GRE Quant: Quantitative Comparison, Problem Solving, and Numeric Entry across difficulty levels.",
  "timeLimitSec": 1260,
  "questions": [
    {
      "id": "q1",
      "category": "Quantitative Comparison",
      "difficulty": "medium",
      "prompt": "Quantity A: $2^{10}$ Quantity B: $10^{3}$\n\nWhich is greater?",
      "choices": [
        { "id": "A", "text": "Quantity A is greater." },
        { "id": "B", "text": "Quantity B is greater." },
        { "id": "C", "text": "The two quantities are equal." },
        { "id": "D", "text": "The relationship cannot be determined." }
      ],
      "answer": "A",
      "explanation": "$2^{10}=1024$ and $10^3=1000$, so Quantity A is greater."
    },
    {
      "id": "q2",
      "category": "Quantitative Comparison",
      "difficulty": "hard",
      "prompt": "If $x$ is a positive integer, Quantity A: $\\dfrac{x}{x+1}$ Quantity B: $\\dfrac{x+1}{x+2}$\n\nWhich is greater?",
      "choices": [
        { "id": "A", "text": "Quantity A is greater." },
        { "id": "B", "text": "Quantity B is greater." },
        { "id": "C", "text": "The two quantities are equal." },
        { "id": "D", "text": "The relationship cannot be determined." }
      ],
      "answer": "B",
      "explanation": "Cross-multiplying: $(x+1)^2$ vs $x(x+2)$ gives $x^2+2x+1 > x^2+2x$, so Quantity B is always greater."
    },
    {
      "id": "q3",
      "category": "Probability",
      "difficulty": "easy",
      "prompt": "A jar contains $3$ red and $5$ blue marbles. If one marble is drawn at random, what is the probability it is red?",
      "choices": [
        { "id": "A", "text": "$\\tfrac{3}{8}$" },
        { "id": "B", "text": "$\\tfrac{3}{5}$" },
        { "id": "C", "text": "$\\tfrac{5}{8}$" },
        { "id": "D", "text": "$\\tfrac{1}{2}$" }
      ],
      "answer": "A",
      "explanation": "There are $3+5=8$ marbles; $P(\\text{red})=\\tfrac{3}{8}$."
    },
    {
      "id": "q4",
      "category": "Algebra",
      "difficulty": "easy",
      "prompt": "If $3^{x} = 81$, what is the value of $x$?",
      "choices": [
        { "id": "A", "text": "$2$" },
        { "id": "B", "text": "$3$" },
        { "id": "C", "text": "$4$" },
        { "id": "D", "text": "$27$" }
      ],
      "answer": "C",
      "explanation": "$81 = 3^4$, so $x=4$."
    },
    {
      "id": "q5",
      "type": "numeric",
      "category": "Numeric Entry",
      "difficulty": "medium",
      "prompt": "Numeric Entry: A jacket priced at \\$60 is discounted by $15\\%$. What is the sale price, in dollars?",
      "choices": [],
      "answer": "51",
      "tolerance": 0.01,
      "unit": "$",
      "explanation": "$15\\%$ of \\$60 is \\$9, so the sale price is $60 - 9 = \\$51$."
    },
    {
      "id": "q6",
      "category": "Arithmetic",
      "difficulty": "easy",
      "prompt": "What is the average (arithmetic mean) of $4$, $6$, $8$, and $10$?",
      "choices": [
        { "id": "A", "text": "$6$" },
        { "id": "B", "text": "$7$" },
        { "id": "C", "text": "$8$" },
        { "id": "D", "text": "$9$" }
      ],
      "answer": "B",
      "explanation": "$\\dfrac{4+6+8+10}{4}=\\dfrac{28}{4}=7$."
    },
    {
      "id": "q7",
      "category": "Algebra",
      "difficulty": "medium",
      "prompt": "If $2x + 3y = 12$ and $x = 3$, what is $y$?",
      "choices": [
        { "id": "A", "text": "$1$" },
        { "id": "B", "text": "$2$" },
        { "id": "C", "text": "$3$" },
        { "id": "D", "text": "$4$" }
      ],
      "answer": "B",
      "explanation": "$2(3) + 3y = 12 \\Rightarrow 6 + 3y = 12 \\Rightarrow y = 2$."
    },
    {
      "id": "q8",
      "category": "Number Properties",
      "difficulty": "hard",
      "prompt": "Quantity A: the number of distinct prime factors of $60$. Quantity B: $3$.\n\nWhich is greater?",
      "choices": [
        { "id": "A", "text": "Quantity A is greater." },
        { "id": "B", "text": "Quantity B is greater." },
        { "id": "C", "text": "The two quantities are equal." },
        { "id": "D", "text": "The relationship cannot be determined." }
      ],
      "answer": "C",
      "explanation": "$60 = 2^2 \\cdot 3 \\cdot 5$ — three distinct primes ($2, 3, 5$). So Quantity A $= 3 =$ Quantity B; they are equal."
    },
    {
      "id": "q9",
      "type": "numeric",
      "category": "Numeric Entry",
      "difficulty": "medium",
      "prompt": "Numeric Entry: If the ratio of $a$ to $b$ is $3:5$ and $b = 20$, what is $a$?",
      "choices": [],
      "answer": "12",
      "explanation": "$\\dfrac{a}{b}=\\dfrac{3}{5} \\Rightarrow a = \\dfrac{3}{5}\\times 20 = 12$."
    },
    {
      "id": "q10",
      "category": "Probability",
      "difficulty": "hard",
      "prompt": "A fair coin is flipped $3$ times. What is the probability of getting exactly $2$ heads?",
      "choices": [
        { "id": "A", "text": "$\\tfrac{1}{8}$" },
        { "id": "B", "text": "$\\tfrac{1}{4}$" },
        { "id": "C", "text": "$\\tfrac{3}{8}$" },
        { "id": "D", "text": "$\\tfrac{1}{2}$" }
      ],
      "answer": "C",
      "explanation": "There are $\\binom{3}{2}=3$ favorable outcomes out of $2^3=8$, so $P=\\tfrac{3}{8}$."
    }
  ]
}
