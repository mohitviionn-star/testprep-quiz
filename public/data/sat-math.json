    {
      "id": "q10",
      "category": "Advanced Math",
      "difficulty": "hard",
      "prompt": "If $x^2 = 49$ and $x < 0$, what is the value of $x$?",
      "choices": [
        { "id": "A", "text": "$-7$" },
        { "id": "B", "text": "$7$" },
        { "id": "C", "text": "$\\pm 7$" },
        { "id": "D", "text": "$-49$" }
      ],
      "answer": "A",
      "explanation": "$x = \\pm 7$, but the constraint $x < 0$ selects $x = -7$."
    },
    {
      "id": "q11",
      "category": "Geometry",
      "difficulty": "hard",
      "prompt": "A circle has area $16\\pi$. What is its radius?",
      "choices": [
        { "id": "A", "text": "$4$" },
        { "id": "B", "text": "$8$" },
        { "id": "C", "text": "$16$" },
        { "id": "D", "text": "$32$" }
      ],
      "answer": "A",
      "explanation": "$\\pi r^2 = 16\\pi \\Rightarrow r^2 = 16 \\Rightarrow r = 4$."
