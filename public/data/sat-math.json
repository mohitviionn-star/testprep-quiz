    {
      "id": "q7",
      "category": "Problem Solving",
      "difficulty": "easy",
      "prompt": "The ratio of boys to girls in a class is $3:5$. If there are $24$ students, how many are girls?",
      "choices": [
        { "id": "A", "text": "$9$" },
        { "id": "B", "text": "$12$" },
        { "id": "C", "text": "$15$" },
        { "id": "D", "text": "$18$" }
      ],
      "answer": "C",
      "explanation": "$3+5=8$ parts; each part $=24/8=3$. Girls $=5\\times3=15$."
    },
    {
      "id": "q8",
      "category": "Problem Solving",
      "difficulty": "medium",
      "prompt": "A shirt's price is increased from \\$40 to \\$50. What is the percent increase?",
      "choices": [
        { "id": "A", "text": "$10\\%$" },
        { "id": "B", "text": "$20\\%$" },
        { "id": "C", "text": "$25\\%$" },
        { "id": "D", "text": "$80\\%$" }
      ],
      "answer": "C",
      "explanation": "Increase $=\\dfrac{50-40}{40}=\\dfrac{10}{40}=25\\%$."
    },
    {
